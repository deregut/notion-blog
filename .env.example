# Notion Integration Token
# https://www.notion.so/my-integrations から取得
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Database ID
# ブログ記事を管理するデータベースの ID
# URL: https://www.notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OGP キャッシュ (S3 互換ストレージ) ---
# 以下 4 種すべてが設定されたときのみ、ビルド前後にリモートと
# tar.gz アーカイブを同期する。設定しなければローカルでは無効。
# Cloudflare R2 / AWS S3 / MinIO など S3 互換であれば何でも可。
#
# Cloudflare R2 を使う場合の例:
#   S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
#   S3_REGION=auto   (省略可、既定 "auto")
# AWS S3 を使う場合の例:
#   S3_ENDPOINT=https://s3.<region>.amazonaws.com
#   S3_REGION=ap-northeast-1
#
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# S3_BUCKET=your-bucket-name
# S3_REGION=auto
# S3_OGP_CACHE_KEY=ogp-cache.tar.gz   (省略可)
