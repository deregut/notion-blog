# Notion Integration Token
# https://www.notion.so/my-integrations から取得
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Database ID
# ブログ記事を管理するデータベースの ID
# URL: https://www.notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- OGP キャッシュ (Cloudflare R2) ---
# 以下 4 種すべてが設定されたときのみ、ビルド前後に R2 と
# tar.gz アーカイブを同期する。設定しなければローカルでは無効。
# R2 → API Tokens から "Object Read & Write" 権限で生成する。
# R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# R2_BUCKET=your-bucket-name
