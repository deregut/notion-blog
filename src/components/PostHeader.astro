---
import type { PostMeta } from "@/lib/notion";

interface Props {
  meta: PostMeta;
  linkTitle?: boolean;
}

const { meta, linkTitle = false } = Astro.props;

const notionColors: Record<string, { bg: string; text: string }> = {
  default: { bg: "#f0efed", text: "#9c9a96" },
  gray:    { bg: "#f0efed", text: "#9c9a96" },
  brown:   { bg: "#f7ece6", text: "#a07060" },
  orange:  { bg: "#fef3e0", text: "#c08040" },
  yellow:  { bg: "#fef9ea", text: "#b09040" },
  green:   { bg: "#eaf5ea", text: "#5a9e7a" },
  blue:    { bg: "#e5f0f8", text: "#5090b8" },
  purple:  { bg: "#f0eaf8", text: "#8060a8" },
  pink:    { bg: "#fceaf3", text: "#c06090" },
  red:     { bg: "#fff0ee", text: "#c06060" },
};

function tagStyle(color: string): string {
  const c = notionColors[color] ?? notionColors.default;
  return `--tag-text:${c.text};--tag-bg:${c.bg}`;
}

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

const publishedDate = formatDate(meta.firstPublishedAt);
---

<header class="post-header">
  <dl class="post-meta">
    <dt class="visually-hidden">公開日</dt>
    <dd>
      <time itemprop="datePublished" datetime={meta.firstPublishedAt}>{publishedDate}</time>
    </dd>
  </dl>
  {
    meta.title &&
      (linkTitle ? (
        <h1 class="post-title" itemprop="headline">
          <a href={`/posts/${meta.id}/`}>{meta.title}</a>
        </h1>
      ) : (
        <h1 class="post-title" itemprop="headline">{meta.title}</h1>
      ))
  }
  {meta.tags.length > 0 && (
    <ul class="post-tags" aria-label="タグ">
      {meta.tags.map((tag) => (
        <li><a class="badge post-tag" href={`/tags/${tag.name}/`} style={tagStyle(tag.color)}>{tag.name}</a></li>
      ))}
    </ul>
  )}
</header>

<style>
  .post-header {
    margin-bottom: 1rem;
  }
  .post-title {
    font-size: 2rem;
    font-weight: bold;
    line-height: 1.3;
    margin-bottom: 0.25rem;
  }
  .post-title a {
    color: var(--bs-body-color);
    text-decoration: none;
  }
  .post-title a:hover {
    color: var(--c-accent);
  }
  .post-meta {
    color: var(--c-text-sub);
    font-size: 0.95rem;
    margin: 0 0 0.6rem;
  }
  .post-meta dt,
  .post-meta dd {
    display: inline;
    margin: 0;
  }
  /* 可視ラベルにのみ装飾を適用 (visually-hidden な dt は影響なし) */
  .post-meta dt:not(.visually-hidden) {
    margin-inline-start: 0.5rem;
  }

  .post-tags {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .post-tag {
    font-weight: normal;
    color: var(--tag-text);
    background: transparent;
    border: 1px solid var(--tag-text);
  }
  .post-tag:hover {
    background: var(--tag-text);
    color: #fff;
    text-decoration: none;
  }

  @media (max-width: 576px) {
    .post-title {
      font-size: 1.5rem;
    }
  }
</style>
