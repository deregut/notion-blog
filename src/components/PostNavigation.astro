---
import type { PostMeta } from "@/lib/notion";

interface Props {
  prev?: PostMeta; // 前の記事（古い方）
  next?: PostMeta; // 次の記事（新しい方）
}

const { prev, next } = Astro.props;

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

{(prev || next) && (
  <nav class="post-navigation my-5" aria-label="前後の記事">
    <div class="nav-card-wrapper">
      {next ? (
        <a class="nav-card nav-card--newer" href={`/posts/${next.id}/`}>
          <span class="nav-label">新しい記事</span>
          <span class="nav-title">{next.title}</span>
          <span class="nav-date">{formatDate(next.firstPublishedAt)}</span>
        </a>
      ) : (
        <div class="nav-card nav-card--empty" aria-hidden="true" />
      )}
      {prev ? (
        <a class="nav-card nav-card--older" href={`/posts/${prev.id}/`}>
          <span class="nav-label">前の記事</span>
          <span class="nav-title">{prev.title}</span>
          <span class="nav-date">{formatDate(prev.firstPublishedAt)}</span>
        </a>
      ) : (
        <div class="nav-card nav-card--empty" aria-hidden="true" />
      )}
    </div>
  </nav>
)}

<style>
  .nav-card-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  @media (max-width: 576px) {
    .nav-card-wrapper {
      grid-template-columns: 1fr;
    }
  }

  .nav-card {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--c-border);
    border-radius: 0.5rem;
    color: var(--bs-body-color);
    text-decoration: none;
  }

  .nav-card:hover {
    border-color: var(--c-accent);
    text-decoration: none;
  }

  .nav-card--older {
    text-align: right;
  }

  .nav-card--empty {
    background: none;
    border: none;
    pointer-events: none;
  }

  .nav-label {
    font-size: 0.8rem;
    color: var(--c-text-sub);
  }

  .nav-card--newer .nav-label::before {
    content: "← ";
  }

  .nav-card--older .nav-label::after {
    content: " →";
  }

  .nav-title {
    font-size: 0.95rem;
    font-weight: bold;
    line-height: 1.4;
  }

  .nav-date {
    font-size: 0.8rem;
    color: var(--c-text-sub);
  }
</style>
