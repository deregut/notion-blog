---
import "bootstrap/dist/css/bootstrap.min.css";
import "@/styles/global.css";
import SiteHeader from "@/components/SiteHeader.astro";
import { siteName, siteDescription, author, copyrightYear } from "@/site";

interface Props {
  title: string;
  description?: string;
  ogType?: string;
  oEmbedUrl?: string;
  robots?: string;
}

const { title, description = siteName, ogType = "website", oEmbedUrl, robots } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogTitle = title || siteName;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <title>{title ? `${title} | ${siteName}` : siteName}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="alternate" type="application/rss+xml" href="/rss.xml" title={siteName} />
    {oEmbedUrl && <link rel="alternate" type="application/json+oembed" href={oEmbedUrl} title={ogTitle} />}
  </head>
  <body>
    <SiteHeader siteName={siteName} siteDescription={siteDescription} />

    <main class="container my-4" style="max-width: 720px;">
      <slot />
    </main>

    <footer class="text-center my-5 py-3 text-body-secondary small">
      <div class="mb-0">&copy; {copyrightYear} {author}</div>
    </footer>
  </body>
</html>
